{
  "baseBranch": "feat/neon-backend",
  "allowedActors": ["kubeden"],
  "allowedAuthorAssociations": ["OWNER", "MEMBER", "COLLABORATOR"],
  "labels": {
    "agentPr": "agent",
    "preview": "preview"
  },
  "commands": {
    "install": "",
    "lint": "deno task lint",
    "test": "",
    "build": "deno task build",
    "migrate": "deno task db:migrate"
  },
  "preview": {
    "enabled": true,
    "workflowFile": "preview-neon.yml",
    "deployCommand": "node scripts/deploy-preview-gitops.mjs",
    "cleanupCommand": "node scripts/cleanup-preview-gitops.mjs",
    "urlFile": ".agent/runtime/preview-url.txt"
  },
  "production": {
    "deployCommand": "node scripts/deploy-production-gitops.mjs",
    "url": "https://md.k6nis.dev",
    "urlFile": ".agent/runtime/production-url.txt",
    "imageRepository": "registry.k6nis.dev/txtwrite/neon",
    "imageTag": "latest",
    "imagePlatform": "linux/amd64",
    "gitopsBranch": "main",
    "deploymentPath": "k8s-cluster-configuration/applications/md/base/deployment.yml",
    "rolloutAnnotation": "txtwrite.k6nis.dev/image-sha"
  },
  "neon": {
    "databaseName": "neondb",
    "roleName": "neondb_owner",
    "pooled": true,
    "ttlHours": 48,
    "deleteOnPrClose": true,
    "publicUrls": {
      "auth": true,
      "dataApi": true,
      "required": true,
      "provisionAuth": true,
      "provisionDataApi": true,
      "authProvider": "better_auth",
      "dataApiAuthProvider": "neon_auth"
    }
  },
  "gitops": {
    "repository": "kubeden/kubeden",
    "checkoutPath": ".agent/runtime/gitops",
    "branch": "txtwrite-previews",
    "baseBranch": "main",
    "previewRoot": "k8s-cluster-configuration/applications/md/previews",
    "imageRepository": "registry.k6nis.dev/txtwrite/neon",
    "imagePlatform": "linux/amd64",
    "appPrefix": "md-pr",
    "hostSuffix": "k6nis.dev",
    "gatewayClassName": "traefik",
    "clusterIssuer": "letsencrypt-prod",
    "containerPort": 4173,
    "servicePort": 80
  },
  "argocd": {
    "server": "https://argocd.k6nis.dev",
    "applicationNamespace": "argocd"
  }
}
