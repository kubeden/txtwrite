{
  "lock": "deno.lock",
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:typescript@5.9.3/tsc -b && deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "lint": "deno run -A npm:eslint .",
    "db:migrate": "deno run -A scripts/migrate.ts",
    "db:migrate:local": "deno run -A --env-file=.env.local scripts/migrate.ts"
  }
}
